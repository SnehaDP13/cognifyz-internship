<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz | Task 2 Secure</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); display: flex; justify-content: center; align-items: center; z-index: 1000; }
        .popup { background: #111; padding: 40px; border-radius: 20px; text-align: center; border: 1px solid #333; }
        
        /* Green Circle with Red Tick */
        .success-icon { width: 100px; height: 100px; margin: 0 auto 20px; }
        .circle { fill: #00ff88; transform-origin: center; animation: grow 0.4s forwards; }
        .tick { fill: none; stroke: #ff3333; stroke-width: 6; stroke-linecap: round; stroke-dasharray: 50; stroke-dashoffset: 50; animation: draw 0.3s forwards 0.4s; }
        
        @keyframes grow { from { transform: scale(0); } to { transform: scale(1); } }
        @keyframes draw { to { stroke-dashoffset: 0; } }

        .warning-strip { color: #ff3333; font-size: 0.7rem; font-weight: 900; text-align: center; margin: 15px 0; border-top: 1px solid #222; border-bottom: 1px solid #222; padding: 5px 0; }
    </style>
</head>
<body>

    <% if (success) { %>
    <div class="overlay">
        <div class="popup">
            <svg class="success-icon" viewBox="0 0 100 100">
                <circle class="circle" cx="50" cy="50" r="45"/>
                <path class="tick" d="M30 50 L45 65 L70 35"/>
            </svg>
            <h2 style="color:white; margin-bottom:20px;">REGISTERED SUCCESSFULLY</h2>
            <button class="btn-green" onclick="window.location.href='/'">CONTINUE</button>
        </div>
    </div>
    <% } %>

    <div class="premium-card">
        <div class="brand-header">
            <div class="brand-name">Cognifyz</div>
            <div class="tagline">Where Data Meets Intelligence</div>
        </div>

        <h2>REGISTRATION</h2>

        <form action="/register" method="POST" onsubmit="return validateForm()">
            <input type="text" name="name" class="input-field" placeholder="FULL NAME" required>
            
           

            <input type="email" name="email" class="input-field" placeholder="EMAIL ADDRESS" required>
            <input type="password" id="pass" name="pass" class="input-field" placeholder="PASSWORD (8+ chars)" required>
            
            <% if (error) { %>
                <p style="color: #ff3333; font-size: 0.8rem; text-align: center;"><%= error %></p>
            <% } %>

            <button type="submit" class="btn-green">REGISTER NOW</button>
        </form>

        <div style="margin-top: 25px; border-top: 1px solid #333; padding-top: 15px;">
            <h3 style="color: #00ff88; font-size: 0.8rem;">SECURE VAULT LOGS:</h3>
            <% logs.forEach(log => { %>
                <div style="font-size: 0.7rem; color: #888; margin-bottom: 4px;">● <%= log.name %> - <%= log.time %></div>
            <% }) %>
        </div>
    </div>

    <script>
        function validateForm() {
            const p = document.getElementById('pass').value;
            if (p.length < 8) {
                alert("Security Error: Password must be at least 8 characters!");
                return false;
            }
            return true;
        }
    </script>
</body>
</html>