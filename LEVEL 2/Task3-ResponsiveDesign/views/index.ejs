<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title><%= title %></title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-crown"></i> Himstun
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#ambiance">Ambiance</a></li>
                    <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" href="#gallery">Gallery</a></li>
                    <li class="nav-item"><a class="nav-link" href="#testimonials">Reviews</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Reserve</a></li>
                </ul>
            </div>
        </div>
    </nav>
    
    <!-- Hero Section -->
    <section id="home" class="hero-section">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <div class="row min-vh-100 align-items-center">
                <div class="col-lg-8 mx-auto text-center text-white">
                    <span class="hero-subtitle animate-fade-in">Welcome to Himstun</span>
                    <h1 class="display-2 fw-bold animate-slide-in">
                        Where Darkness Meets <br><span class="brand-highlight">Culinary Excellence</span>
                    </h1>
                    <p class="lead mt-4 animate-fade-in">
                        Experience the pinnacle of fine dining in an atmosphere of sophisticated elegance. 
                        Our Michelin-starred cuisine awaits you.
                    </p>
                    <div class="mt-5 animate-bounce">
                        <a href="#contact" class="btn btn-primary btn-lg cta-btn">
                            <i class="fas fa-calendar-alt"></i> Reserve Your Table
                        </a>
                        <a href="#ambiance" class="btn btn-outline-light btn-lg ms-3">
                            <i class="fas fa-video"></i> Explore Ambiance
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Ambiance Section -->
    <section id="ambiance" class="ambiance-section py-5">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-tag">The Atmosphere</span>
                <h2 class="section-title">Luxurious Ambiance</h2>
                <p class="section-subtitle">Step into a world of refined luxury and comfort</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="ambiance-card">
                        <div class="ambiance-image">
                            <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&h=400&fit=crop" alt="Main Dining Hall">
                            <div class="ambiance-overlay">
                                <i class="fas fa-search-plus"></i>
                            </div>
                        </div>
                        <div class="ambiance-content">
                            <h4>Grand Dining Hall</h4>
                            <p>Elegant chandeliers, plush velvet seating, and intimate candlelit ambiance</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="ambiance-card">
                        <div class="ambiance-image">
                            <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&h=400&fit=crop" alt="Private Lounge">
                            <div class="ambiance-overlay">
                                <i class="fas fa-search-plus"></i>
                            </div>
                        </div>
                        <div class="ambiance-content">
                            <h4>VIP Lounge</h4>
                            <p>Exclusive private dining with personalized butler service</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="ambiance-card">
                        <div class="ambiance-image">
                            <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=600&h=400&fit=crop" alt="Rooftop Terrace">
                            <div class="ambiance-overlay">
                                <i class="fas fa-search-plus"></i>
                            </div>
                        </div>
                        <div class="ambiance-content">
                            <h4>Rooftop Terrace</h4>
                            <p>Breathtaking city views with al fresco dining under the stars</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Features Section -->
    <section id="features" class="features-section py-5">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-tag">Why Choose Us</span>
                <h2 class="section-title">The Himstun Experience</h2>
                <p class="section-subtitle">Discover what makes our dining experience truly exceptional</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card text-center p-4">
                        <div class="feature-icon">
                            <i class="fas fa-utensils"></i>
                        </div>
                        <h4>Michelin-Starred Cuisine</h4>
                        <p>World-class culinary creations by award-winning chefs</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card text-center p-4">
                        <div class="feature-icon">
                            <i class="fas fa-wine-bottle"></i>
                        </div>
                        <h4>Premium Wine Cellar</h4>
                        <p>Curated collection of fine wines from around the world</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card text-center p-4">
                        <div class="feature-icon">
                            <i class="fas fa-music"></i>
                        </div>
                        <h4>Live Jazz Evenings</h4>
                        <p>Enjoy soothing live music every weekend</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card text-center p-4">
                        <div class="feature-icon">
                            <i class="fas fa-concierge-bell"></i>
                        </div>
                        <h4>24/7 Concierge</h4>
                        <p>Dedicated staff ensuring an unforgettable experience</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Gallery Section -->
    <section id="gallery" class="gallery-section py-5">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-tag">Culinary Art</span>
                <h2 class="section-title">Signature Dishes</h2>
                <p class="section-subtitle">Masterpieces crafted with passion and precision</p>
            </div>
            <div class="row g-4">
                <div class="col-sm-6 col-lg-3">
                    <div class="gallery-item">
                        <img src="https://images.unsplash.com/photo-1544025162-d76694265947?w=400&h=300&fit=crop" alt="Truffle Risotto">
                        <div class="gallery-overlay">
                            <h5>Truffle Risotto</h5>
                            <p>Arborio rice, black truffle, parmesan</p>
                            <span class="price">$42</span>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="gallery-item">
                        <img src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=400&h=300&fit=crop" alt="Lobster Thermidor">
                        <div class="gallery-overlay">
                            <h5>Lobster Thermidor</h5>
                            <p>Fresh lobster, creamy sauce, gratin</p>
                            <span class="price">$68</span>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="gallery-item">
                        <img src="https://images.unsplash.com/photo-1600891964092-4316c288032e?w=400&h=300&fit=crop" alt="Wagyu Beef">
                        <div class="gallery-overlay">
                            <h5>Wagyu Beef</h5>
                            <p>A5 Japanese Wagyu, truffle sauce</p>
                            <span class="price">$95</span>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="gallery-item">
                        <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=400&h=300&fit=crop" alt="Chocolate Soufflé">
                        <div class="gallery-overlay">
                            <h5>Chocolate Soufflé</h5>
                            <p>Dark chocolate, vanilla bean ice cream</p>
                            <span class="price">$24</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Testimonials Section -->
    <section id="testimonials" class="testimonials-section py-5">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-tag">Guest Reviews</span>
                <h2 class="section-title">What Our Guests Say</h2>
                <p class="section-subtitle">Real experiences from our valued patrons</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="testimonial-card p-4">
                        <div class="stars">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                        </div>
                        <p class="mt-3">"An unforgettable dining experience! The ambiance is breathtaking and the food is absolutely divine. Himstun exceeded all expectations."</p>
                        <div class="testimonial-author">
                            <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="Sarah Johnson">
                            <div>
                                <strong>Sarah Johnson</strong>
                                <span>Food Critic</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="testimonial-card p-4">
                        <div class="stars">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                        </div>
                        <p class="mt-3">"Best restaurant in the city! The black truffle risotto is to die for. The service is impeccable and the atmosphere is pure luxury."</p>
                        <div class="testimonial-author">
                            <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Michael Chen">
                            <div>
                                <strong>Michael Chen</strong>
                                <span>Regular Diner</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="testimonial-card p-4">
                        <div class="stars">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                        </div>
                        <p class="mt-3">"Exceptional service and attention to detail. The private lounge is perfect for business dinners. Highly recommended for fine dining."</p>
                        <div class="testimonial-author">
                            <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="Emily Rodriguez">
                            <div>
                                <strong>Emily Rodriguez</strong>
                                <span>Business Executive</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Contact / Booking Section -->
    <section id="contact" class="contact-section py-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-6">
                    <span class="section-tag text-start d-block">Reservations</span>
                    <h2 class="section-title text-start">Secure Your Table</h2>
                    <p class="mb-4">Experience culinary excellence. Reserve your table for an unforgettable dining journey at Himstun.</p>
                    
                    <!-- Error Messages Display -->
                    <div id="errorMessages" class="mb-3"></div>
                    
                    <!-- Success Message (for non-AJAX fallback) -->
                    <% if (success && success !== null) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> <%= success %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>
                    
                    <!-- Error Messages (for non-AJAX fallback) -->
                    <% if (errors && errors.length > 0) { %>
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i> Please fix the following errors:
                            <ul class="mb-0 mt-2">
                                <% errors.forEach(function(error) { %>
                                    <li><%= error %></li>
                                <% }); %>
                            </ul>
                        </div>
                    <% } %>
                    
                    <form id="bookingForm" method="POST" action="/book-table">
                        <div class="mb-3">
                            <label class="form-label"><i class="fas fa-user"></i> Full Name</label>
                            <input type="text" name="name" class="form-control" placeholder="John Doe" value="<%= formData && formData.name ? formData.name : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label"><i class="fas fa-phone"></i> Phone Number</label>
                            <input type="tel" name="phone" class="form-control" placeholder="1234567890" maxlength="10" value="<%= formData && formData.phone ? formData.phone : '' %>" required>
                            <small class="text-muted">Enter 10-digit mobile number</small>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><i class="fas fa-calendar"></i> Date</label>
                                <input type="date" name="date" class="form-control" value="<%= formData && formData.date ? formData.date : '' %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><i class="fas fa-clock"></i> Time</label>
                                <select name="time" class="form-control" required>
                                    <option value="">Select Time</option>
                                    <option value="17:00" <%= formData && formData.time === '17:00' ? 'selected' : '' %>>5:00 PM</option>
                                    <option value="18:00" <%= formData && formData.time === '18:00' ? 'selected' : '' %>>6:00 PM</option>
                                    <option value="19:00" <%= formData && formData.time === '19:00' ? 'selected' : '' %>>7:00 PM</option>
                                    <option value="20:00" <%= formData && formData.time === '20:00' ? 'selected' : '' %>>8:00 PM</option>
                                    <option value="21:00" <%= formData && formData.time === '21:00' ? 'selected' : '' %>>9:00 PM</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><i class="fas fa-users"></i> Number of Guests</label>
                                <input type="number" name="guests" class="form-control" min="1" max="20" value="<%= formData && formData.guests ? formData.guests : 2 %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><i class="fas fa-chair"></i> Seating Preference</label>
                                <select name="seating" class="form-control">
                                    <option value="indoor" <%= formData && formData.seating === 'indoor' ? 'selected' : '' %>>Indoor Dining</option>
                                    <option value="private" <%= formData && formData.seating === 'private' ? 'selected' : '' %>>Private Lounge</option>
                                    <option value="outdoor" <%= formData && formData.seating === 'outdoor' ? 'selected' : '' %>>Rooftop Terrace</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label"><i class="fas fa-comment"></i> Special Requests</label>
                            <textarea name="specialRequest" class="form-control" rows="3" placeholder="Dietary restrictions, allergies, special occasions..."><%= formData && formData.specialRequest ? formData.specialRequest : '' %></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 cta-btn">
                            <i class="fas fa-check-circle"></i> Reserve Your Table
                        </button>
                    </form>
                </div>
                <div class="col-lg-6">
                    <div class="contact-info p-4">
                        <h4><i class="fas fa-map-marker-alt"></i> Visit Us</h4>
                        <p>123 Luxury Avenue, Downtown District<br>New York, NY 10001</p>
                        
                        <h4 class="mt-4"><i class="fas fa-clock"></i> Opening Hours</h4>
                        <p><strong>Tuesday - Sunday:</strong> 5:00 PM - 11:00 PM<br>
                        <strong>Monday:</strong> Closed<br>
                        <strong>Weekend Brunch:</strong> 11:00 AM - 3:00 PM</p>
                        
                        <h4 class="mt-4"><i class="fas fa-phone-alt"></i> Contact</h4>
                        <p><strong>Reservations:</strong> +1 (212) 555-0123<br>
                        <strong>Private Events:</strong> +1 (212) 555-0124<br>
                        <strong>Email:</strong> reservations@himstun.com</p>
                        
                        <h4 class="mt-4"><i class="fas fa-clock"></i> Dress Code</h4>
                        <p>Smart Casual / Business Attire<br>
                        <small>Jackets recommended for gentlemen</small></p>
                        
                        <div class="mt-4">
                            <h4><i class="fas fa-parking"></i> Valet Parking</h4>
                            <p>Complimentary valet parking available</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Current Bookings Display -->
    <section id="bookingsList" class="bookings-section py-5">
        <div class="container">
            <div class="text-center mb-4">
                <h3 class="section-title">Current Reservations</h3>
                <p>View and manage your upcoming bookings</p>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover">
                            <thead>
                                <tr>
                                    <th>Booking ID</th>
                                    <th>Name</th>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Guests</th>
                                    <th>Seating</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (bookings && bookings.length > 0) { %>
                                    <% bookings.slice().reverse().forEach(function(booking) { %>
                                    <tr>
                                        <td>#<%= booking.id %></td>
                                        <td><%= booking.name %></td>
                                        <td><%= booking.date %></td>
                                        <td><%= booking.time %></td>
                                        <td><%= booking.guests %></td>
                                        <td><%= booking.seating === 'indoor' ? 'Indoor' : booking.seating === 'private' ? 'Private' : 'Rooftop' %></td>
                                        <td><span class="badge bg-success">Confirmed</span></td>
                                        <td>
                                            <form action="/cancel-booking" method="POST" style="display: inline;">
                                                <input type="hidden" name="bookingId" value="<%= booking.id %>">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Cancel this booking?')">
                                                    <i class="fas fa-times"></i> Cancel
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">No reservations yet. Be the first to book!</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-crown"></i> Himstun</h5>
                    <p>Where culinary artistry meets timeless elegance. Creating unforgettable dining experiences since 2010.</p>
                    <div class="social-links mt-3">
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-yelp"></i></a>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="#home">Home</a></li>
                        <li><a href="#ambiance">Ambiance</a></li>
                        <li><a href="#features">Features</a></li>
                        <li><a href="#gallery">Gallery</a></li>
                        <li><a href="#testimonials">Reviews</a></li>
                        <li><a href="#contact">Reservations</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Newsletter</h5>
                    <p>Subscribe for exclusive offers and events</p>
                    <div class="input-group">
                        <input type="email" class="form-control" placeholder="Your email">
                        <button class="btn btn-primary" type="button">Subscribe</button>
                    </div>
                </div>
            </div>
            <hr>
            <div class="text-center py-3">
                <p>&copy; 2024 Himstun Restaurant. All rights reserved. | Cognifyz Technologies Internship</p>
            </div>
        </div>
    </footer>
    
    <!-- Success Popup Modal -->
    <div class="modal fade" id="successModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header border-bottom border-primary">
                    <h5 class="modal-title">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Booking Confirmed!
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center mb-4">
                        <i class="fas fa-crown fa-3x text-primary mb-3"></i>
                        <h4>Welcome to Himstun!</h4>
                        <p class="text-muted">Your reservation has been successfully confirmed.</p>
                    </div>
                    
                    <div id="popupBookingDetails" class="booking-details p-3 bg-secondary bg-opacity-25 rounded">
                        <!-- Booking details will be inserted here dynamically for AJAX, or populated from server -->
                        <% if (bookingData && bookingData !== null) { %>
                            <p class="mb-2"><strong>Booking ID:</strong> #<%= bookingData.id %></p>
                            <p class="mb-2"><strong>Name:</strong> <%= bookingData.name %></p>
                            <p class="mb-2"><strong>Phone:</strong> <%= bookingData.phone %></p>
                            <p class="mb-2"><strong>Date:</strong> <%= bookingData.date %></p>
                            <p class="mb-2"><strong>Time:</strong> <%= bookingData.time %></p>
                            <p class="mb-2"><strong>Guests:</strong> <%= bookingData.guests %></p>
                            <p class="mb-2"><strong>Seating:</strong> <%= bookingData.seating === 'indoor' ? 'Indoor Dining' : bookingData.seating === 'private' ? 'Private Lounge' : 'Rooftop Terrace' %></p>
                            <% if (bookingData.specialRequest) { %>
                                <p class="mb-0"><strong>Special Request:</strong> <%= bookingData.specialRequest %></p>
                            <% } %>
                        <% } %>
                    </div>
                    
                    <div class="alert alert-success mt-3 mb-0">
                        <i class="fas fa-envelope"></i> A confirmation SMS has been sent to your mobile number
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                    <a href="#contact" class="btn btn-primary" data-bs-dismiss="modal">Make Another Booking</a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="/js/script.js"></script>
    
    <!-- Auto-show modal script when bookingData exists -->
    <% if (bookingData && bookingData !== null && success) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var modal = new bootstrap.Modal(document.getElementById('successModal'));
            modal.show();
        });
    </script>
    <% } %>
    
    <!-- Additional CSS for toast notifications -->
    <style>
        .toast-notification {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--primary-color, #d4af37);
            color: #000;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 500;
            z-index: 9999;
            animation: slideIn 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .toast-notification.success {
            background: #28a745;
            color: white;
        }
        
        .toast-notification.error {
            background: #dc3545;
            color: white;
        }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        @keyframes slideOut {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(100%);
                opacity: 0;
            }
        }
    </style>
</body>
</html>