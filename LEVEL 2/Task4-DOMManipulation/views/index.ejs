<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title><%= title %></title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts - Luxury Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <div class="brand-icon">
                    <i class="fas fa-crown"></i>
                    <span class="brand-glow"></span>
                </div>
                <span class="brand-text">HIMSTUN</span>
                <span class="brand-dot">.</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-page="home">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-page="profile">
                            <i class="fas fa-user"></i> Profile
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-page="dashboard">
                            <i class="fas fa-chart-line"></i> Dashboard
                        </a>
                    </li>
                </ul>
                <!-- Theme Toggle Button -->
                <div class="theme-toggle-wrapper ms-3">
                    <button class="theme-toggle-btn" id="themeToggle">
                        <i class="fas fa-sun theme-icon-sun"></i>
                        <i class="fas fa-moon theme-icon-moon"></i>
                        <span class="toggle-slider"></span>
                    </button>
                </div>
            </div>
        </div>
    </nav>
    
    <div class="container mt-5 pt-4">
        <!-- Dynamic Page Content -->
        <div id="pageContent">
            <div class="text-center py-5">
                <div class="luxury-spinner">
                    <i class="fas fa-crown"></i>
                </div>
                <p class="mt-3 loading-text">Loading Himstun Experience...</p>
            </div>
        </div>
    </div>
    
    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container"></div>
    
    <!-- Terms Modal -->
    <div class="modal fade" id="termsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-gavel"></i> Terms & Conditions</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Welcome to Himstun Restaurant! By registering, you agree to:</p>
                    <ul class="mt-3">
                        <li><i class="fas fa-check-circle"></i> Provide accurate personal information</li>
                        <li><i class="fas fa-check-circle"></i> Be at least 18 years of age</li>
                        <li><i class="fas fa-check-circle"></i> Respect our reservation policies</li>
                        <li><i class="fas fa-check-circle"></i> Receive booking confirmations via SMS/Email</li>
                    </ul>
                    <hr>
                    <small class="text-muted">Last updated: January 2024</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">I Agree</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="/js/script.js"></script>
</body>
</html>